# ============================================================
#  Moni's Munchies — Environment Variables
#  Copy this file to .env and fill in your real values:
#    cp .env.example .env
#    nano .env
#
#  NEVER commit .env to GitHub — it's in .gitignore
# ============================================================

# ── Stripe ────────────────────────────────────────────────────────
# Get from: stripe.com → Developers → API Keys
# Use the SECRET key (sk_live_... for production, sk_test_... for testing)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY

# Stripe webhook signing secret (required for /api/stripe-webhook).
# Get from: stripe.com → Developers → Webhooks → click your endpoint
#           → "Signing secret" (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SIGNING_SECRET

# ── Resend (transactional email for order notifications) ─────────
# Get from: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_API_KEY

# Where new-order notifications are sent
ORDER_NOTIFY_EMAIL=orders@monismunchies.com

# Who the email appears "from" — must be an address on a verified Resend domain
ORDER_FROM_EMAIL="Moni's Munchies Orders <orders@monismunchies.com>"

# ── Your site URL (no trailing slash) ─────────────────────────────
SITE_URL=https://monismunchies.com

# ── Server port ───────────────────────────────────────────────────
# Port map on this VPS:
#   3000 = scout-consultatory, 3001 = docker-pr, 3002 = monismunchies
# Must match proxy_pass in the nginx config.
PORT=3002

# ── Mailchimp ─────────────────────────────────────────────────────
# API Key: mailchimp.com → Account → Extras → API Keys
# List ID: Audience → Settings → Audience name and defaults → Audience ID
# Server:  first part of API key after the dash (e.g. "us1", "us14")
MAILCHIMP_API_KEY=REPLACE_WITH_YOUR_MAILCHIMP_API_KEY
MAILCHIMP_LIST_ID=REPLACE_WITH_YOUR_AUDIENCE_ID
MAILCHIMP_SERVER=us1
